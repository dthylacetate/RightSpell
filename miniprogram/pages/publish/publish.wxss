.container { padding: 40rpx; background: #fff; min-height: 100vh; }
.header { font-size: 40rpx; font-weight: bold; margin-bottom: 40rpx; color: #333; }

.form-group { margin-bottom: 30rpx; }
.label { font-size: 28rpx; color: #666; display: block; margin-bottom: 12rpx; font-weight: bold; }

.input, .picker-box, .textarea {
  background: #f8f8f8; padding: 24rpx; border-radius: 12rpx; font-size: 28rpx;
}
.picker-box { color: #333; min-height: 40rpx; }
.textarea { width: 100%; height: 240rpx; box-sizing: border-box; }

.submit-btn {
  background: #1976d2 !important; color: #fff; margin-top: 60rpx;
  border-radius: 50rpx; font-weight: bold;
}
.tips { font-size: 22rpx; color: #ccc; text-align: center; margin-top: 30rpx; }