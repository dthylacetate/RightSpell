<view class="container">
  <view class="header">💬 乐手交流区</view>

  <view class="forum-card" wx:for="{{forumList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
    
    <view class="author-info">
      <image class="mini-avatar" src="{{item.authorAvatar}}"></image>
      <text class="author-name">{{item.authorName ? item.authorName : '匿名乐手'}}</text>
    </view>

    <view class="forum-title">{{item.title}}</view>
    
    <view class="forum-content">{{item.content}}</view>

    <view class="forum-footer">
      <text class="comments">💬 {{item.commentCount || 0}} 条评论</text>
    </view>
    
  </view> <view class="publish-fab" bindtap="goToForumPublish">
    <text>✍️ 发起讨论</text>
  </view>
</view>