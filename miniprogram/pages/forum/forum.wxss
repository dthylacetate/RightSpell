page {
  background-color: #f6f6f6;
}

/* 1. 顶部吸顶区域 */
.header-sticky {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: #fff;
  z-index: 1000;
  padding-bottom: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f1f1f1;
  margin: 20rpx 30rpx;
  padding: 15rpx 30rpx;
  border-radius: 40rpx;
}

.search-box input {
  flex: 1;
  font-size: 26rpx;
  margin-left: 15rpx;
}

.tab-scroll {
  white-space: nowrap;
  padding: 0 30rpx 10rpx;
  height: 60rpx;
}

.tab-item {
  display: inline-block;
  font-size: 28rpx;
  color: #666;
  margin-right: 40rpx;
  padding-bottom: 10rpx;
}

.tab-item.active {
  color: #ff9800;
  font-weight: bold;
  border-bottom: 4rpx solid #ff9800;
}

/* 2. 帖子卡片流 */
.post-list {
  padding: 20rpx;
}

.post-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

/* ✨ 重点：控制讨论区列表头像大小 */
.user-avatar {
  width: 80rpx !important;    /* 列表头像设定为 80rpx */
  height: 80rpx !important;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;             /* 防止被标题挤扁 */
  background-color: #eee;
}

.author-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-meta {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.post-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.post-tag {
  font-size: 20rpx;
  color: #ff9800;
  background: #fff3e0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 帖子内容预览 */
.post-main {
  margin-bottom: 24rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.post-excerpt {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  /* 最多显示两行，超出省略 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 底部互动统计 */
.post-footer {
  display: flex;
  border-top: 1rpx solid #f2f2f2;
  padding-top: 20rpx;
}

.footer-stat {
  font-size: 24rpx;
  color: #999;
  margin-right: 40rpx;
  display: flex;
  align-items: center;
}

.footer-stat .icon {
  margin-right: 8rpx;
}

/* 悬浮发布按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ffb74d, #ff9800);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(255,152,0,0.3);
  z-index: 2000;
}

.fab-icon { font-size: 36rpx; }
.fab-text { font-size: 18rpx; color: #fff; font-weight: bold; }