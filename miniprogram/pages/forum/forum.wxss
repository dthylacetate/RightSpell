.container {
  padding: 30rpx;
  background-color: #f5f6f8; /* 给背景加一点浅灰色，区分卡片 */
  min-height: 100vh;
}

.header {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

/* 论坛卡片样式 */
.forum-card {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.forum-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.forum-content {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2; /* 限制最多显示两行，超出显示省略号 */
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.forum-footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

/* 悬浮发布按钮 */
.publish-fab {
  position: fixed;
  bottom: 80rpx;
  right: 40rpx;
  background-color: #ff5722; /* 换个显眼的橙红色 */
  color: #ffffff;
  padding: 24rpx 40rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 16rpx rgba(255,87,34,0.3);
  font-weight: bold;
}


/* 作者信息区域排版 */
.author-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 迷你圆形头像 */
.mini-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 16rpx;
}

/* 作者昵称文字 */
.author-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* 让标题更加突出 */
.forum-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}