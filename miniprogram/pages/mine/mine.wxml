<view class="container">
  <block wx:if="{{!hasUserInfo}}">
    <view class="login-box">
      <view class="tips">请先登录，解锁发帖和组队功能</view>
      <button type="primary" bindtap="login">微信一键登录</button>
    </view>
  </block>

  <block wx:else>
    <view class="user-profile" bindtap="goToEditProfile">
      <view class="avatar-box">
        <image wx:if="{{userInfo.avatarUrl}}" class="real-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text wx:else>🎸</text>
      </view> 
      <view class="user-info">
        <view class="nickname">{{userInfo.nickname ? userInfo.nickname : '新乐手'}}</view>
        <view class="edit-hint">擅长：{{userInfo.instrument ? userInfo.instrument : '点击设置'}} ></view>
      </view>
    </view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="goToMyPosts">
        <text>我的发帖</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item">
        <text>我的乐队</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="logout">
        <text>退出登录</text>
        <text class="arrow">></text>
      </view>
    </view>
  </block>
</view>