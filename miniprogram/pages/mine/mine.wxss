/* pages/mine/mine.wxss *//* 针对新加的真实头像图片的样式 */
.real-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%; /* 变成正圆形 */
  display: block;
}

/* 确保外部头像框的尺寸固定（如果你之前没写的话） */
.avatar-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx; /* 如果没头像显示emoji时的字体大小 */
  overflow: hidden; /* 防止图片溢出 */
  margin-right: 30rpx;
}

.user-info {
  flex: 1; /* 让文字部分占据剩余空间 */
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.edit-hint {
  font-size: 26rpx;
  color: #888;
}


.menu-list {
  margin-top: 40rpx;
  background-color: #fff;
  border-radius: 20rpx;
  /* 如果你背景是白的，可以加个阴影让列表显出来 */
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); 
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 32rpx;
  color: #333;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}