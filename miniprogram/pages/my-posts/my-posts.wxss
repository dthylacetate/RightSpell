page { background: #f7f7f7; padding-bottom: 50rpx; }

.header { padding: 40rpx 30rpx; }
.title { font-size: 40rpx; font-weight: bold; display: block; }
.subtitle { font-size: 24rpx; color: #999; margin-top: 10rpx; }

.post-card {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.card-content { padding: 30rpx; }

.manage-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fafafa;
  border-top: 1rpx solid #eee;
}

.time { font-size: 22rpx; color: #bbb; }

.btn-delete {
  margin: 0 !important;
  padding: 10rpx 30rpx !important;
  font-size: 24rpx !important;
  color: #ff4d4f;
  background: #fff1f0;
  border: 1rpx solid #ffa39e;
  border-radius: 30rpx;
  min-height: 0 !important;
  width: auto !important;
}

/* 空状态样式 */
.empty { text-align: center; padding-top: 200rpx; }
.empty image { width: 200rpx; height: 200rpx; margin-bottom: 30rpx; }
.empty text { display: block; color: #999; font-size: 28rpx; }
.go-publish {
  margin-top: 40rpx;
  background: #ff9800;
  color: #fff;
  border-radius: 40rpx;
  width: 240rpx !important;
}

.btn-edit {
  margin-right: 20rpx !important;
  padding: 10rpx 30rpx !important;
  font-size: 24rpx !important;
  color: #ff9800;
  background: #fff;
  border: 1rpx solid #ff9800;
  border-radius: 30rpx;
  width: auto !important;
  min-height: 0 !important;
}