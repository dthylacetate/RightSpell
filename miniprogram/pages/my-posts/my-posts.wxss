.container {
  padding: 30rpx;
}
.header {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}
/* 沿用首页的卡片样式 */
.post-card {
  border: 2rpx solid #eee;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.post-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.post-tags {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}