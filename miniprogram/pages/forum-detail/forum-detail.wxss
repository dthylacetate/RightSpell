.container { padding: 30rpx; background: #fff; min-height: 100vh; padding-bottom: 120rpx; }

/* 帖子样式 */
.main-post { border-bottom: 20rpx solid #f8f8f8; padding-bottom: 40rpx; margin-bottom: 40rpx; }
.author-bar { display: flex; align-items: center; margin-bottom: 30rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; }
.name { font-size: 30rpx; font-weight: bold; }
.time { font-size: 24rpx; color: #999; }
.title { font-size: 40rpx; font-weight: bold; margin-bottom: 24rpx; }
.content { font-size: 32rpx; line-height: 1.6; color: #444; }

/* 留言列表样式 */
.list-title { font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; }
.comment-item { display: flex; margin-bottom: 30rpx; }
.c-avatar { width: 60rpx; height: 60rpx; border-radius: 50%; margin-right: 20rpx; }
.c-name { font-size: 26rpx; color: #666; font-weight: bold; }
.c-text { font-size: 28rpx; color: #333; margin-top: 6rpx; }

/* 底部输入框固定 */
.input-panel {
  position: fixed; bottom: 0; left: 0; width: 100%;
  background: #fff; padding: 20rpx 30rpx; display: flex;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); box-sizing: border-box;
}
.msg-input {
  flex: 1; background: #f5f5f5; padding: 16rpx 30rpx;
  border-radius: 40rpx; font-size: 28rpx; margin-right: 20rpx;
}
.send-btn {
  background: #ff5722 !important; color: #fff; width: 140rpx !important;
  font-size: 26rpx; border-radius: 40rpx; padding: 0;
  display: flex; align-items: center; justify-content: center;
}


.c-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.c-time {
  font-size: 22rpx;
  color: #b2b2b2;
}
/* --- 1. 楼主头像（稍微威风一点） --- */
.author-avatar {
  width: 90rpx !important;    /* 楼主设定为 90rpx */
  height: 90rpx !important;
  border-radius: 50%;         /* 圆形 */
  margin-right: 20rpx;
  flex-shrink: 0;             /* 防止被右侧文字挤扁 */
  background-color: #eee;
  display: block;             /* 消除幽灵间隙 */
}

/* --- 2. 评论区用户头像（小巧精致） --- */
.comment-avatar {
  width: 70rpx !important;    /* 评论者设定为 70rpx */
  height: 70rpx !important;
  border-radius: 50%;
  margin-right: 18rpx;
  flex-shrink: 0;
  background-color: #f0f0f0;
  display: block;
}

/* --- 3. 配套布局优化 --- */
.author-bar {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.comment-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.comment-main {
  flex: 1; /* 让内容占据剩余宽度 */
}