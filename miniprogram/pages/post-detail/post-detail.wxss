.container {
  padding: 40rpx;
  background-color: #fafafa;
  min-height: 100vh;
}

.header-section {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.tags-container {
  display: flex;
  gap: 20rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: bold;
}
.instrument-tag { background-color: #e3f2fd; color: #1976d2; }
.style-tag { background-color: #fce4ec; color: #c2185b; }

.content-section, .contact-section {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #333;
  padding-left: 16rpx;
}

.content-text {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
}

.contact-box {
  background-color: #f5f5f5;
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 留言区域 */
.comment-section {
  margin-top: 40rpx;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  padding-bottom: 140rpx; /* 给底部输入框留出空间 */
}

.comment-item { display: flex; margin-bottom: 30rpx; }
.c-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 20rpx; background: #eee; }
.c-name { font-size: 26rpx; color: #888; margin-bottom: 4rpx; }
.c-text { font-size: 30rpx; color: #333; line-height: 1.4; }
.empty-tips { text-align: center; color: #ccc; font-size: 26rpx; padding: 40rpx 0; }

/* 底部输入框 */
.comment-input-bar {
  position: fixed; bottom: 0; left: 0; width: 100%;
  background: #fff; padding: 20rpx 30rpx; display: flex;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); box-sizing: border-box;
  z-index: 100;
}
.comment-input {
  flex: 1; background: #f5f5f5; padding: 16rpx 30rpx;
  border-radius: 40rpx; font-size: 28rpx; margin-right: 20rpx;
}
.send-btn {
  background: #1976d2 !important; /* 招募区建议用蓝色系，区分讨论区的橙色 */
  color: #fff; width: 140rpx !important;
  font-size: 26rpx; border-radius: 40rpx; padding: 0;
  display: flex; align-items: center; justify-content: center;
}

.c-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.c-time {
  font-size: 22rpx;
  color: #b2b2b2;
}

/* 容器底部留白，防止内容被输入框遮挡 */
.container {
  padding-bottom: 140rpx; 
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 15rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom); /* 适配留海屏 */
}

.comment-input {
  flex: 1;
  height: 76rpx;
  background: #f2f2f2;
  border-radius: 38rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.send-btn {
  width: 140rpx !important;
  height: 76rpx;
  line-height: 76rpx;
  background: #ff9800; /* 招募橙 */
  color: #fff;
  font-size: 28rpx;
  border-radius: 38rpx;
  padding: 0;
  font-weight: bold;
}

/* 评论列表样式 */
.comment-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.comment-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #eee;
}

.comment-main { flex: 1; }
.comment-nickname { font-size: 26rpx; color: #666; font-weight: 500; }
.comment-text { font-size: 30rpx; color: #333; margin: 8rpx 0; line-height: 1.5; }
.comment-time { font-size: 22rpx; color: #bbb; }
.no-comment { text-align: center; color: #999; padding: 60rpx 0; font-size: 26rpx; }

/* pages/post-detail/post-detail.wxss */

/* ✨ 新增或覆盖：作者信息整行布局，确保垂直居中 */
.author-row {
  display: flex;
  align-items: center; /* 头像和文字垂直居中对齐 */
  padding: 0 30rpx 30rpx; /* 调整间距，配合新的头部布局 */
}

/* ✨ 重点修复：给头像强行戴上紧箍咒 */
.avatar {
  width: 90rpx !important;    /* 强行写死宽度，根据需要调大或调小 */
  height: 90rpx !important;   /* 强行写死高度，保持 1:1 */
  border-radius: 50%;         /* 圆形头像 */
  margin-right: 20rpx;         /* 顶开右侧文字 */
  
  /* 辅助：防止图片加载前后的闪烁或撑破布局 */
  background-color: #f0f0f0;  /* 占位背景色 */
  flex-shrink: 0;             /* 关键：防止在 flex 布局下被挤压变形 */
  display: block;             /* 消除图片底部的幽灵间隙 */
}

/* 作者名字和风格区域 */
.author-info {
  flex: 1; /* 占据剩余空间 */
  display: flex;
  flex-direction: column; /* 文字上下排列 */
}

.nickname {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.style-tag {
  font-size: 22rpx;
  color: #777;
}

/* --- 留言区整体布局 --- */
.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: flex-start; /* 让头像对齐留言的第一行文字 */
}

/* ✨ 重点修复：留言者的小头像 */
.mini-avatar {
  width: 64rpx !important;    /* 留言头像稍小一些，显得精致 */
  height: 64rpx !important;
  border-radius: 50%;         /* 圆形 */
  margin-right: 20rpx;
  flex-shrink: 0;             /* 极其重要：防止被长留言挤压变形 */
  background-color: #eee;     /* 占位色 */
  display: block;
}

/* 留言主体内容区域 */
.comment-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.comment-user {
  font-size: 26rpx;
  font-weight: bold;
  color: #555;
  margin-bottom: 8rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 10rpx;
}
/* 编辑按钮容器 */
.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  
  /* 尺寸与间距 */
  padding: 8rpx 24rpx;
  margin-left: 20rpx;
  
  /* 边框与背景 */
  background: rgba(255, 152, 0, 0.08); /* 极浅的橙色背景 */
  border: 2rpx solid #ff9800;          /* 招募橙边框 */
  border-radius: 40rpx;                /* 胶囊形状 */
  
  /* 动画过渡 */
  transition: all 0.3s ease;
}

/* 按钮文字 */
.edit-btn text {
  font-size: 24rpx;
  font-weight: 500;
  color: #ff9800; /* 文字颜色与边框一致 */
}

/* 图标微调 */
.edit-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
  line-height: 1;
}

/* ✨ 交互反馈：按下时的视觉效果 */
.edit-btn:active {
  transform: scale(0.92);             /* 轻轻缩小，有弹性感 */
  background: rgba(255, 152, 0, 0.2); /* 背景加深 */
}