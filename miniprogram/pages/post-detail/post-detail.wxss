.container {
  padding: 40rpx;
  background-color: #fafafa;
  min-height: 100vh;
}

.header-section {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.tags-container {
  display: flex;
  gap: 20rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: bold;
}
.instrument-tag { background-color: #e3f2fd; color: #1976d2; }
.style-tag { background-color: #fce4ec; color: #c2185b; }

.content-section, .contact-section {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #333;
  padding-left: 16rpx;
}

.content-text {
  font-size: 30rpx;
  color: #555;
  line-height: 1.6;
}

.contact-box {
  background-color: #f5f5f5;
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 留言区域 */
.comment-section {
  margin-top: 40rpx;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  padding-bottom: 140rpx; /* 给底部输入框留出空间 */
}

.comment-item { display: flex; margin-bottom: 30rpx; }
.c-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 20rpx; background: #eee; }
.c-name { font-size: 26rpx; color: #888; margin-bottom: 4rpx; }
.c-text { font-size: 30rpx; color: #333; line-height: 1.4; }
.empty-tips { text-align: center; color: #ccc; font-size: 26rpx; padding: 40rpx 0; }

/* 底部输入框 */
.comment-input-bar {
  position: fixed; bottom: 0; left: 0; width: 100%;
  background: #fff; padding: 20rpx 30rpx; display: flex;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); box-sizing: border-box;
  z-index: 100;
}
.comment-input {
  flex: 1; background: #f5f5f5; padding: 16rpx 30rpx;
  border-radius: 40rpx; font-size: 28rpx; margin-right: 20rpx;
}
.send-btn {
  background: #1976d2 !important; /* 招募区建议用蓝色系，区分讨论区的橙色 */
  color: #fff; width: 140rpx !important;
  font-size: 26rpx; border-radius: 40rpx; padding: 0;
  display: flex; align-items: center; justify-content: center;
}

.c-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.c-time {
  font-size: 22rpx;
  color: #b2b2b2;
}