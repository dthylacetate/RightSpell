page {
  background-color: #f8f8f8;
}

.container {
  padding: 30rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.avatar-wrapper {
  padding: 0;
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  position: relative;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-edit-tag {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 卡片布局 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.no-border {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.input, .picker-box {
  font-size: 28rpx;
  color: #333;
  height: 40rpx;
  line-height: 40rpx;
}

.placeholder {
  color: #ccc;
}

.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  background: #fafafa;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  color: #333;
}

/* 按钮样式 */
.save-btn {
  background: linear-gradient(135deg, #ffb74d, #ff9800);
  color: #fff;
  border-radius: 50rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 20rpx rgba(255,152,0,0.3);
}

.bottom-gap {
  height: 60rpx;
}

.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-bottom: 20rpx;
}

.img-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
}

.img-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.del-btn {
  position: absolute;
  top: -15rpx;
  right: -15rpx;
  background: #ff5252;
  color: #fff;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  z-index: 10;
}

.add-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}