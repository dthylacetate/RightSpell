<view class="container">
  <view class="avatar-section">
    <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
      <view class="avatar-edit-tag">更换头像</view>
    </button>
    <text class="hint">点击头像可直接修改</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">乐手昵称</text>
      <input class="input" type="nickname" placeholder="想个响亮的外号" value="{{nickname}}" bindblur="inputNickname" />
    </view>

    <view class="form-item">
      <text class="label">所在校区</text>
      <input class="input" placeholder="如：沙河 / 本部 / 海南" value="{{campus}}" bindinput="inputCampus" />
    </view>

    <view class="form-item">
      <text class="label">主攻乐器</text>
      <picker bindchange="changeInstrument" range="{{instruments}}">
        <view class="picker-box {{instrument ? '' : 'placeholder'}}">
          {{instrument || '请选择你的本命乐器'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">琴龄 / 艺龄</text>
      <picker bindchange="changeYears" range="{{yearOptions}}">
        <view class="picker-box {{years ? '' : 'placeholder'}}">
          {{years || '大约玩了多久？'}}
        </view>
      </picker>
    </view>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">擅长风格</text>
      <input class="input" placeholder="如：Metal, Funk, J-Pop..." value="{{styles}}" bindinput="inputStyles" />
    </view>

    <view class="form-item no-border">
      <text class="label">我的设备 (Gear)</text>
      <textarea 
        class="textarea" 
        placeholder="晒晒你的家伙事儿，如：Dingwall, Darkglass全家桶" 
        value="{{gear}}" 
        bindinput="inputGear" 
        maxlength="200"
      />
    </view>

    <view class="form-item no-border">
      <text class="label">设备美照 (最多3张)</text>
      <view class="image-uploader">
        <view class="img-item" wx:for="{{gearImagesLocal}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" bindtap="previewLocalImg" data-url="{{item}}"></image>
          <view class="del-btn" catchtap="deleteImg" data-index="{{index}}">×</view>
        </view>
        
        <view class="add-btn" bindtap="chooseGearImages" wx:if="{{gearImagesLocal.length < 3}}">
          <view class="plus">+</view>
          <view class="add-text">添加图片</view>
        </view>
      </view>
    </view>
  </view>

  <view class="form-card">
    <view class="form-item no-border">
      <text class="label">个人简介 (Bio)</text>
      <textarea 
        class="textarea" 
        placeholder="聊聊你的音乐态度，或者想找什么样的队友..." 
        value="{{bio}}" 
        bindinput="inputBio" 
        maxlength="300"
      />
    </view>
  </view>

  <button class="save-btn" bindtap="submitProfile">保存乐手名片</button>
  <view class="bottom-gap"></view>
</view>