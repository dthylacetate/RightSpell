<view class="filter-wrapper">
  
  <view class="search-bar">
    <icon class="search-icon" type="search" size="14" color="#999"></icon>
    <input 
      class="search-input" 
      placeholder="查找风格、艺人或关键词..." 
      value="{{searchKey}}"
      bindinput="onSearchInput"
      bindconfirm="getPosts"
      confirm-type="search"
    />
    <text class="clear-btn" wx:if="{{searchKey}}" bindtap="clearSearch">取消</text>
  </view>

  <view class="filter-row type-row">
    <view 
      class="filter-tag {{currType === '' ? 'active' : ''}}" 
      bindtap="filterByType" data-type="">全部</view>
    <view 
      class="filter-tag {{currType === '招募乐手' ? 'active' : ''}}" 
      bindtap="filterByType" data-type="招募乐手">招募中</view>
    <view 
      class="filter-tag {{currType === '个人求组队' ? 'active' : ''}}" 
      bindtap="filterByType" data-type="个人求组队">求带走</view>
  </view>

  <scroll-view class="filter-row scroll-row" scroll-x enable-flex>
    <view 
      class="instrument-item {{currInstrument === '' ? 'active' : ''}}" 
      bindtap="filterByIns" data-ins="">全乐器</view>
    <view 
      class="instrument-item {{currInstrument === item ? 'active' : ''}}" 
      wx:for="{{instruments}}" 
      wx:key="*this"
      bindtap="filterByIns" 
      data-ins="{{item}}">{{item}}</view>
  </scroll-view>
</view>

<view class="top-placeholder" style="height: 260rpx;"></view>

<view class="container">
  
  <view 
    class="post-card" 
    wx:for="{{postList}}" 
    wx:key="_id" 
    bindtap="goToDetail" 
    data-id="{{item._id}}"
  >
    <view class="card-title-row">
      <text class="type-tag {{item.type === '个人求组队' ? 'tag-person' : 'tag-band'}}">
        {{item.type || '招募中'}}
      </text>
      <text class="post-title">{{item.title}}</text>
    </view>
    
    <view class="card-info">
      <text class="info-item">🎸 {{item.instrument}}</text>
      <text class="info-item">🎵 {{item.style}}</text>
    </view>

    <view class="card-footer">
      <view class="author">
        <image class="mini-avatar" src="{{item.authorAvatar || '/images/default-avatar.png'}}"></image>
        <text class="author-name">{{item.authorName || '匿名乐手'}}</text>
      </view>

    </view>
  </view>

  <view class="no-data" wx:if="{{postList.length === 0}}">
    <icon type="info" size="60" color="#ddd"></icon>
    <view class="no-data-text">没有找到相关的招募信息</view>
    <view class="no-data-sub">换个关键词或者乐器试试吧？</view>
  </view>

</view>

<view class="fab-btn" bindtap="goToPublish">
  <text class="fab-icon">+</text>
  <text class="fab-text">发布</text>
</view>