/* 1. 卡片整体容器 */
.post-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); /* 淡淡的阴影增加高级感 */
}

/* 2. 标题行布局 */
.card-title-row {
  display: flex;
  align-items: flex-start; /* 标题长的话可以换行 */
  margin-bottom: 16rpx;
}

/* 3. 标签优化 */
.type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 16rpx;
  margin-top: 6rpx; /* 微调对齐 */
  white-space: nowrap;
}

.post-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  line-height: 1.4;
}

/* 4. 关键：控制图片显示 */
.post-image {
  width: 100%;
  height: 320rpx; /* 固定高度，防止页面忽长忽短 */
  border-radius: 8rpx;
  margin: 20rpx 0;
  background: #f0f0f0;
}

/* 5. 底部信息栏（作者+评论数） */
.card-footer {
  display: flex;
  justify-content: space-between; /* 名字在左，评论在右 */
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5; /* 一条淡淡的分割线 */
}

.author {
  display: flex;
  align-items: center;
}

.mini-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.author-name {
  font-size: 26rpx;
  color: #666;
}

.comment-num {
  font-size: 24rpx;
  color: #999;
}